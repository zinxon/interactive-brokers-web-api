# Copy to .env and fill in your values:
#   cp .env.example .env

# Required: your IBKR account ID (e.g. U1234567)
IBKR_ACCOUNT_ID=

# Optional: for "Download activity statement" on the Portfolio page
# Create an Activity Flex Query in Client Portal: Reporting > Flex Queries
IBKR_FLEX_TOKEN=
IBKR_FLEX_QUERY_ID=
